-              : buf_shift_foldpc(dfi[2:0], decodeBufAcceptNum, decodeBufFoldpc);
-        end else if (!decodeBufValid[0] && feNotAcceptDropOr[dfi]) begin
-          decodeBufFoldpc[dfi] <=
