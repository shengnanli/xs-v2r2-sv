-              : buf_shift_foldpc(dfi[2:0], decodeFromFrontendAcceptNum, cfVecFoldpc);
-        end
-      end
-    end
-  end
-
   generate
     for (gj = 0; gj < ctrlblock_pkg::DecodeWidth; gj++) begin : g_decinfoldpc
